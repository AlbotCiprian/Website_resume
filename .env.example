# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub API (strongly recommended on Vercel production to avoid 403/rate limits)
GITHUB_TOKEN=

# Contact form (required for real email sending)
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Resend (preferred)
RESEND_API_KEY=

# SMTP fallback (optional, only if RESEND_API_KEY is not used)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_USE_ENTERPRISE=false
RECAPTCHA_V3_MIN_SCORE=0.1
RECAPTCHA_V3_BYPASS=false
